# Exchange credentials. Leave blank for paper mode.
BINANCE_API_KEY=  # Mandatory only for live or testnet trading. Optional in paper mode.
BINANCE_API_SECRET=  # Mandatory only for live or testnet trading. Optional in paper mode.

# paper or live
BOT_MODE=paper  # Mandatory. Choose `paper` or `live`.

# Simulated starting balance for paper mode and sizing baseline.
BOT_INITIAL_EQUITY=1000  # Optional. Used as the paper balance and as the sizing baseline.

# Symbols to scan when BOT_TRADE_ALL_SYMBOLS=false.
BOT_SYMBOLS=BTCUSDT,ETHUSDT  # Optional. Used when BOT_TRADE_ALL_SYMBOLS=false.

# Strategy and market universe controls.
BOT_ALLOW_SHORT=true  # Optional. Enable short trades.
BOT_TRADE_ALL_SYMBOLS=false  # Optional. If true, scan all exchange symbols for the selected quote asset.
BOT_QUOTE_ASSET=USDT  # Optional. Quote asset used when BOT_TRADE_ALL_SYMBOLS=true.
BOT_STRATEGY_PROFILE=default  # Optional. Saved strategy profile name.
BOT_CANDLE_STYLE=raw  # Optional. Candle style used by the strategy engine.
BOT_INTERVAL=5m  # Optional. Candle timeframe.
BOT_CANDLES_LIMIT=200  # Optional. Number of candles fetched per symbol.
BOT_POLL_SECONDS=20  # Optional. Seconds between bot loop runs.

# Risk, sizing, and leverage.
BOT_LEVERAGE=3  # Optional. Target leverage per trade.
BOT_MAX_LEVERAGE=3  # Optional. Hard cap for leverage.
BOT_RISK_PER_TRADE_PCT=1.0  # Optional. Percent of equity risked per trade.
BOT_RISK_REWARD_RATIO=2.0  # Optional. Reward multiple used for take profit sizing.
BOT_MAX_OPEN_POSITIONS=5  # Optional. Maximum concurrent open positions.
BOT_MAX_POSITION_PCT=25.0  # Optional. Max allocation per trade as a percent of equity.
BOT_STOP_LOSS_PCT=1.5  # Optional. Fallback stop loss percent when no strategy exit plan is produced.
BOT_TAKE_PROFIT_PCT=3.0  # Optional. Fallback take profit percent when no strategy exit plan is produced.
BOT_TRAILING_STOP_PCT=1.0  # Optional. Trailing stop percent used by local trailing updates.
BOT_TRAILING_STAGE_ENABLED=false  # Optional. If true, use break-even and delayed trailing activation.
BOT_TRAILING_BREAK_EVEN_R=0.8  # Optional. Move stop to break-even after this many R.
BOT_TRAILING_ACTIVATION_R=1.2  # Optional. Start active trailing after this many R.
BOT_TRAILING_FEE_BUFFER_PCT=0.04  # Optional. Small break-even buffer for fees/slippage.
BOT_MAX_DAILY_LOSS_PCT=5.0  # Optional. Daily loss guard as a percent of initial equity.
BOT_MIN_MARGIN_BUFFER_PCT=25.0  # Optional. Minimum free margin buffer before new trades are blocked.

# Backtest speed and caching.
BOT_BACKTEST_DURATION=12w  # Optional. Default backtest duration.
BOT_BACKTEST_MAX_CANDLES=0  # Optional. Cap candles used by backtests. 0 keeps full duration.
BOT_BACKTEST_EVAL_WINDOW=320  # Optional. Rolling candle window used by backtest evaluation.
BOT_BACKTEST_CACHE_ENABLED=true  # Optional. Reuse downloaded candle history across backtests.
BOT_BACKTEST_CACHE_TTL_HOURS=0  # Optional. 0 disables cache expiry.
BOT_BACKTEST_CACHE_DIR=data/cache/backtest_candles  # Optional. Candle cache directory.

# Live trade safety.
BOT_LIVE_TRADING_CONFIRMED=false  # Mandatory for live mainnet unless BINANCE_TESTNET=true.
BINANCE_TESTNET=false  # Optional. Set true to use Binance Futures testnet.

# Protective order mode for live trading:
# - local_only: exits are enforced only by the bot loop after price checks.
# - local_and_exchange: also place Binance algo TP/SL/trailing orders.
BOT_LIVE_PROTECTION_MODE=local_and_exchange  # Optional. Applies only in live mode.

# Exchange endpoints.
BINANCE_BASE_URL=https://fapi.binance.com  # Optional. Override only if you need a custom production endpoint.
BINANCE_TESTNET_URL=https://testnet.binancefuture.com  # Optional. Used automatically when BINANCE_TESTNET=true.

# Local storage.
BOT_DATA_DIR=data  # Optional. Local storage paths.
BOT_DB_PATH=data/bot.db  # Optional. Local storage paths.
